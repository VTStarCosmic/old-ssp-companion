//Handles item interactions, specifically. Need to add more.
OnItemGive
{
	if reference0 == "Candy"
	{
		if candycount > 0
		{
		cumulative_candies += 1
		candycount -= 1
		//should be parallel EVAL("")
		
		"Candy, huh? \w5 \s[11] You know me too well, %(catchphrase)! \w5 Ahuhuhuh!\e"
		}
		else
		{
			"(You don't have any candy to give!)\w5\e"
			//SSP doesn't seem to be able to handle negative numbers here, so you don't have to worry about going below 0.
		}
	}
	elseif reference0 == "Delivery"
	{
		parallel EVAL("Delivery_Array")
		deliveryflag = 0
	}
	else
	{
		"An error has occured in OnItemGive.\e"
	}
}

//Set this so that if there's no event, it doesn't blank out. Or change it in boot. Add weather effects in as an RNG function every hour
EventChat
{
	_eventString = EVAL("Event_%(Curr_Event)")
	"%(_eventString)\e"
}

/*For those with no programming experience, the below function may seem confusing. What's essentially happening here is  
simple--I'm putting clean lines to separate the menus into the menu, while also displaying the entire menu and formatting it.
The menu choices and functions are stored as strings in an array, and this function appends the menu formatting onto them
while also splitting off the function part. If you're not into coding, this isn't a complication you wanna make,
but if you know what you're doing, it allows for some slick copy and pasting, and easy formatting.*/
OnHobbyMenuDisp
{
	//put a for loop in here to print out the characters
	//or maybe build a menu display function that reads in menu arrays, sizes them, for loops, and links to their functions
	"Ask about:\n\_q"
	--
	_txt = ''
	_array = Menu_Array_BobHobbies //work smarter, not harder--you can copy the code and only change this name for the display if you have multiple menus like this.

	for _i = 0; _i < ARRAYSIZE(_array); _i++ //no () makes me cry
	{
		if _array[_i] == "-" //replaces '-'s in the array with this pretty divider. You can change either marker or divider to whatever you want.
		{
			_txt += "\n\────────────────────────"
		}
		else
		{
			_split = SPLIT(_array[_i],".")
			_txt += "\n\![*]\q[%(_split[0]),%(_split[1])]"
		}
	}
	_txt
}

