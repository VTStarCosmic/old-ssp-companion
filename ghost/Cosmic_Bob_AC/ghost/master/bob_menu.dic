}

OnSickItemMenu
{
	"[Items:]\n"
	--
	"\![*]\q[Candy,sickCandy]\n"
	--
	if givenMedicine != 1
	{
	"\![*]\q[Medicine,Medicine]\n"
	}
	--
	if givenBlanket != 1
	{
	"\![*]\q[Blanket,Blanket]\n"
	}
	--
	"\![*]\q[Cancel,BACKTOMENU]\e"
}

//Sick variables from Item Menu

Select.sickCandy
{
	OnSickItemGive
}

Select.Medicine
{
	OnSickItemGive
}

Select.Blanket
{
	OnSickItemGive
}

//Add more dialogue here.
OnSickItemGive
{
	if reference0 == "sickCandy"
	{
		"I like candy, but I'm not really feeling well right not, %(nickname)...maybe later.\e"
	}
	elseif reference0 == "Medicine"
	{
		"Some medicine? Thank you so much, %(username). -drinks- Ugh, it tastes icky...but hopefully I'll feel better soon! Thanks, %(catchphrase)!\e"
		sickhelp += 1
	}
	elseif reference0 == "Blanket"
	{
		"A blanket...? Thanks, %(catchphrase). I don't feel as cold now.\e"
		sickhelp += 1
	}
	else
	{
		"An error has occurred in OnSickItemGive.\e"
	}
	sickhelp += 1
}

Select.sickbab
{
	if foodtally <= 3
	{
		sickhelp += 1
	"Thank you...It's nice to have something to eat, even if I'm not very hungry...\e" //soup icon? or various foods
	}
	else
	{
		"I'm full now...but thank you for all the food, %(catchphrase).\e"
	}
}

