//Begin the obligatory date/time formatting stuff.
GetWeekDay
{
	if weekday == 0
	{"Sunday"}
	elseif weekday == 1
	{"Monday"}
	elseif weekday == 2
	{"Tuesday"}
	elseif weekday == 3
	{"Wednesday"}
	elseif weekday == 4
	{"Thursday"}
	elseif weekday == 5
	{"Friday"}
	else
	{"Saturday"}
}

GetAP
{
 	if hour >= 0 && hour <= 11
 		{
 			"AM"
 		}
 	else
 		{
 			"PM"
 		}
}

Getnowmin
{
	if minute >= 0 && minute <=9
	{"0%(minute)"}
	else
	{"%(minute)"}
}

Getnowhour
{
	if hour12 >= 0 && hour12 <=9
	{"0%(hour12)"}
	else
	{"%(hour12)"}
}