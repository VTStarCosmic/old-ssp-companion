/*Stuff for the sick menu.
I COULD just mod the regular menu functions to account for him being sick...Either way works.
I just like this way because it keeps it condensed for testing.*/
SickMenuRun
{
	wd = GetWeekDay
 	ap = GetAP
 	nowmin = Getnowmin
 	nowhour = Getnowhour
	//all of the variables
	--
	"\n\n\_q\b2" //quick session
	--
	if lastTalk != ""
	{
	/*This function appears when the ghost has said something from AITalk beforehand, by default. If you want it to include menu response dialogue,
	you'll have to define them manually by setting them to lastTalk*/
	  "\![*]\q[Repeat Last Dialogue,OnLastTalk]\n\n[half]"	  
	}
	--
 	"\![*]\q[Say something,OnAITalk]\n"
	--
	"\![*]\q[Eat something,sickbab]\n"
	--
	"\![*]\q[Items & Interaction,sickitemselect]\n"
	--
	"...\n"
	--
	"\![*]\q[Cancel,CANCEL]\n\n\n[half]%(wd) %(nowhour):%(nowmin) %(ap), %(month)/%(day)/%(year)\e" 
}

Select.sickitemselect
{
