//Old tidbit of good practice from my beta ghost release
/*TO ADD A NEW CHARACTER:
-Add them to the CharacterList array
-Make a Select.-character name- here and call OnCharDialogue in it
-Make a properly-named array for them in the character dialogue file.*/

Select.Fishing
{
	OnHobbyDialogue
}

Select.Eating
{
	OnHobbyDialogue
}

Menu_Array_BobHobbies : array
{
	"-"
	"Fishing.Fishing"
	"Eating.Eating"
}

OnHobbyDialogue //This is the same functionality as OnCharDialogue from my Meta Knight ghost, if he ever gets published.
{
	if ISFUNC("Hobby_%(reference0)")
	{
		_array = EVAL("Hobby_%(reference0)")
		_text = _array[RAND(ARRAYSIZE(EVAL("Hobby_%(reference0)")))]
		"%(_text)"
		lastTalk = _text //IF YOU DON'T ADD lastTalk HERE, NOTHING YOU SAY IN MENUS WILL BE REPEATABLE
	}
	else
	{
		"An error has occurred in OnHobbyDialogue.\e"
	}
}

Hobby_Fishing
{
	"test fishing dialogue\e"
}

Hobby_Eating
{
	"test eating dialogue.\e"
}

//puts lastTalk in the quotes. Doesn't it already end with \e?
OnLastTalk 
{
	"%(lastTalk)\e"
}

