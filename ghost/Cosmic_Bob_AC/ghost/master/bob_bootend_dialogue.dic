bootArray_timeslot_earlymorning : array //5AM-9AM
{
	"\0\s[16]Zzzzz\w8\w8.\w8.\w8.\w8Mmmm\w8.\w8.\w8.\w8\w8Oh, hello\w8.\w8.\w8.\w8good morning, %(catchphrase)\w8.\w8.\w8.\w8It's too early\w8.\w8.\w8.\w8\e"
}

