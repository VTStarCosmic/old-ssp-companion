/*NONSPECIFIC BOOT*/

bootArray_Nonspecific : array
{
	//conditionals, trust, etc. in here
	"Oh, hello there. Good to see you're still alive and hopefully-well.\e"
	//"!!\nOh, you interrupted me while I was eating my lunch. Just some %(lunch), but...\e"
	//why is that one not time related.
	{
	_string = "Hi %(username), how are you?"
	--
	if MTTrust > 4
	{
		_string = _string + " ...it's nice to see you."
	}
	--
	"%(_string)\e"
	}
}

