//Valentine's Day 2-14
boot_2_14 : array
{
	
}

//Leap Year 2-29
boot_2_29 : array
{
	if MTTrust > 2
	{
	"It's the dedicated leap year date on your planet, isn't it? It...intrigues me, to say the least. I've done some research on your planet to see how it was divided, actually...Interesting to see how the scientific minds of different times think so similarly. But anyway. Happy Leap Day, if that's what you call it.\e"
	}
	else
	{
	"It's the dedicated leap year date on your planet, isn't it? It intrigues me, to say the least.\e"
	}
}

//4-20 
boot_4_20 : array
{
	//meme trigger
	if ALLOFTHEMEMES == 1
	{
		"Oh gosh...how many dank memes can we get away with with YOU at the wheel today? To be honest, you could probably teach me a thing or two...\e"
	}
	else
	{
	"Oh, hello...I feel...almost as if I should point out what day it is...but I'm not for sure. I sent King Dedede an annoying text, at least.\e"
	}
}

//Memorial Day?

