/*TIME FUNCTIONS (put down here because once you get them you never change them so out of my way you go)*/

GetTimeSlot //You actually aren't confined to these names or timeslots; you can change them as long as they line up. I modified the lunch hour slightly myself.
//may tamper with the rest of them later to suit my tastes...they're pretty good now to be honest though.
{
	if hour >= 5 && hour <= 8
	{
		"earlymorning"
	}
	elseif hour >= 9 && hour <= 11
	{
		"morning"
	}
	elseif hour >= 12 && hour <= 13
	{
		"lunch"
	}
	elseif hour >= 14 && hour <= 17
	{
		"afternoon"
	}
	elseif hour >= 18 && hour <= 20
	{
		"evening"
	}
	elseif hour >= 21 && hour <= 24
	{
		"latenight"
	}
	else
	{
		"midnight"
	}
}

//I stole this function from the default ghost. However, I have changed some of the values/times to my tastes.
GetSeasonSlot
{
	_a = GETTIME
	_m = _a[1]
	_d = _a[2]
	
	case GETTIME[1] {
		when 1 {
			'winter'
		}
		when 2 {
			'winter'
		}
		when 3 {
			if _d <= 8 
			{
				'winter'
			}
			else 
			{
				'spring'
			}
		}
		when 4 {
			'spring'
		}
		when 5 {
			'spring'
		}
		when 6 {
			'summer'
		}
		when 7 {
			'summer'
		}
		when 8 {
			'summer'
		}
		when 9 {
			if _d <= 8 
			{
				'summer'
			}
			else 
			{
				'fall'
			}
		}
		when 10 {
			'fall'
		}
		when 11 {
			'fall'
		}
		when 12 {
			'winter'
		}
	}
}